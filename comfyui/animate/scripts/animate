#!/usr/bin/env bash
# Animate a still image into a short video using SVD via ComfyUI.
set -euo pipefail

usage() {
  cat <<EOF
Usage: animate --input <path> [options]
       animate --image <drive_file_id> [options]

Options:
  --input <path>          Local image file
  --image <id>            Google Drive file ID
  --frames <n>            Number of frames: 14 or 25 (default: 14)
  --motion <n>            Motion intensity 0-255 (default: 127)
  --fps <n>               Output framerate (default: 8)
  --seed <n>              Random seed (default: random)
  --output <path>         Local output path
  --output-folder <id>    Google Drive folder ID to upload result
EOF
  exit 1
}

COMFYUI_URL="${COMFYUI_URL:-http://localhost:8188}"
INPUT="" IMAGE_ID="" FRAMES=14 MOTION=127 FPS=8 SEED=$RANDOM
OUTPUT="" OUTPUT_FOLDER=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --input)         INPUT="$2"; shift 2 ;;
    --image)         IMAGE_ID="$2"; shift 2 ;;
    --frames)        FRAMES="$2"; shift 2 ;;
    --motion)        MOTION="$2"; shift 2 ;;
    --fps)           FPS="$2"; shift 2 ;;
    --seed)          SEED="$2"; shift 2 ;;
    --output)        OUTPUT="$2"; shift 2 ;;
    --output-folder) OUTPUT_FOLDER="$2"; shift 2 ;;
    *) echo "Unknown option: $1"; usage ;;
  esac
done

[[ -z "$INPUT" && -z "$IMAGE_ID" ]] && { echo "Error: --input or --image required"; usage; }

TMPDIR=$(mktemp -d)
trap 'rm -rf "$TMPDIR"' EXIT

# ── Resolve input ─────────────────────────────────────────────────────
if [[ -n "$IMAGE_ID" ]]; then
  echo "Downloading from Drive..."
  INPUT="$TMPDIR/input.png"
  gws drive files get \
    --params "{\"fileId\": \"$IMAGE_ID\", \"alt\": \"media\"}" \
    -o "$INPUT"
fi

[[ -s "$INPUT" ]] || { echo "Error: input file is empty or missing"; exit 1; }
BASENAME=$(basename "${INPUT%.*}")

# ── Upload to ComfyUI ────────────────────────────────────────────────
echo "Uploading to ComfyUI..."
UPLOAD_RESPONSE=$(curl -sf -X POST "$COMFYUI_URL/upload/image" \
  -F "image=@$INPUT;filename=input.png" -F "overwrite=true")
UPLOAD_NAME=$(echo "$UPLOAD_RESPONSE" | jq -r '.name // empty')
[[ -n "$UPLOAD_NAME" ]] || { echo "Error: upload failed"; exit 1; }

# ── Queue animate workflow ────────────────────────────────────────────
WORKFLOW=$(cat <<WORKFLOW_EOF
{
  "1": {
    "class_type": "ImageOnlyCheckpointLoader",
    "inputs": { "ckpt_name": "svd_xt.safetensors" }
  },
  "2": {
    "class_type": "LoadImage",
    "inputs": { "image": "$UPLOAD_NAME" }
  },
  "3": {
    "class_type": "SVD_img2vid_Conditioning",
    "inputs": {
      "clip_vision": ["1", 1],
      "init_image": ["2", 0],
      "vae": ["1", 2],
      "width": 1024,
      "height": 576,
      "video_frames": $FRAMES,
      "motion_bucket_id": $MOTION,
      "fps": 8,
      "augmentation_level": 0.0
    }
  },
  "4": {
    "class_type": "KSampler",
    "inputs": {
      "model": ["1", 0],
      "positive": ["3", 0],
      "negative": ["3", 1],
      "latent_image": ["3", 2],
      "seed": $SEED,
      "steps": 20,
      "cfg": 2.5,
      "sampler_name": "euler",
      "scheduler": "karras",
      "denoise": 1.0
    }
  },
  "5": {
    "class_type": "VAEDecode",
    "inputs": { "samples": ["4", 0], "vae": ["1", 2] }
  },
  "6": {
    "class_type": "SaveAnimatedWEBP",
    "inputs": {
      "images": ["5", 0],
      "filename_prefix": "animate",
      "fps": $FPS,
      "lossless": false,
      "quality": 85,
      "method": "default"
    }
  }
}
WORKFLOW_EOF
)

echo "Animating ($FRAMES frames, motion=$MOTION, seed=$SEED)..."
QUEUE_RESPONSE=$(curl -sf -X POST "$COMFYUI_URL/prompt" \
  -H "Content-Type: application/json" \
  -d "{\"prompt\": $WORKFLOW}")
PROMPT_ID=$(echo "$QUEUE_RESPONSE" | jq -r '.prompt_id // empty')
[[ -n "$PROMPT_ID" ]] || { echo "Error: failed to queue: $QUEUE_RESPONSE"; exit 1; }

# ── Poll for completion ───────────────────────────────────────────────
for i in $(seq 1 180); do
  HISTORY=$(curl -sf "$COMFYUI_URL/history/$PROMPT_ID")
  STATUS=$(echo "$HISTORY" | jq -r ".[\"$PROMPT_ID\"].status.completed // empty")

  if [[ "$STATUS" == "true" ]]; then
    FILENAME=$(echo "$HISTORY" | jq -r ".[\"$PROMPT_ID\"].outputs[\"6\"].images[0].filename // empty")
    [[ -n "$FILENAME" ]] && break
  fi

  ERROR=$(echo "$HISTORY" | jq -r ".[\"$PROMPT_ID\"].status.status_str // empty")
  [[ "$ERROR" == "error" ]] && { echo "Error: animation failed"; exit 1; }

  sleep 5
done
[[ -n "${FILENAME:-}" ]] || { echo "Error: timed out after 15 minutes"; exit 1; }

# ── Download and convert to MP4 ──────────────────────────────────────
curl -sf "$COMFYUI_URL/view?filename=$FILENAME&subfolder=&type=output" \
  -o "$TMPDIR/output.webp"

# Convert WEBP animation to MP4
ffmpeg -y -i "$TMPDIR/output.webp" \
  -c:v libx264 -pix_fmt yuv420p -movflags +faststart \
  "$TMPDIR/output.mp4" 2>/dev/null \
  || { echo "Error: ffmpeg conversion failed"; exit 1; }

# ── Output ────────────────────────────────────────────────────────────
if [[ -n "$OUTPUT_FOLDER" ]]; then
  echo "Uploading to Drive..."
  gws drive files create \
    --params '{"uploadType": "multipart"}' \
    --json "{\"name\": \"${BASENAME}_animated.mp4\", \"parents\": [\"$OUTPUT_FOLDER\"]}" \
    --upload "$TMPDIR/output.mp4" \
    --fields "id,name,webViewLink"
else
  OUTPUT="${OUTPUT:-/tmp/animate-${SEED}.mp4}"
  cp "$TMPDIR/output.mp4" "$OUTPUT"
  echo "Saved to: $OUTPUT"
fi

echo "Done. Seed=$SEED (use same seed to reproduce)."
