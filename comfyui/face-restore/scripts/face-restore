#!/usr/bin/env bash
# Restore faces in a photo using CodeFormer via ComfyUI.
set -euo pipefail

usage() {
  cat <<EOF
Usage: face-restore --input <path> [options]
       face-restore --image <drive_file_id> [options]

Options:
  --input <path>          Local image file
  --image <id>            Google Drive file ID
  --fidelity <0.0-1.0>   Quality vs faithfulness (default: 0.5)
  --output <path>         Local output path (default: <input>_restored.png)
  --output-folder <id>    Google Drive folder ID to upload result
EOF
  exit 1
}

COMFYUI_URL="${COMFYUI_URL:-http://localhost:8188}"
INPUT="" IMAGE_ID="" FIDELITY=0.5 OUTPUT="" OUTPUT_FOLDER=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --input)         INPUT="$2"; shift 2 ;;
    --image)         IMAGE_ID="$2"; shift 2 ;;
    --fidelity)      FIDELITY="$2"; shift 2 ;;
    --output)        OUTPUT="$2"; shift 2 ;;
    --output-folder) OUTPUT_FOLDER="$2"; shift 2 ;;
    *) echo "Unknown option: $1"; usage ;;
  esac
done

[[ -z "$INPUT" && -z "$IMAGE_ID" ]] && { echo "Error: --input or --image required"; usage; }

TMPDIR=$(mktemp -d)
trap 'rm -rf "$TMPDIR"' EXIT

# ── Resolve input ─────────────────────────────────────────────────────
if [[ -n "$IMAGE_ID" ]]; then
  echo "Downloading from Drive..."
  INPUT="$TMPDIR/input.png"
  gws drive files get \
    --params "{\"fileId\": \"$IMAGE_ID\", \"alt\": \"media\"}" \
    -o "$INPUT"
fi

[[ -s "$INPUT" ]] || { echo "Error: input file is empty or missing"; exit 1; }
BASENAME=$(basename "${INPUT%.*}")

# ── Upload to ComfyUI ────────────────────────────────────────────────
echo "Uploading to ComfyUI..."
UPLOAD_RESPONSE=$(curl -sf -X POST "$COMFYUI_URL/upload/image" \
  -F "image=@$INPUT;filename=input.png" -F "overwrite=true")
UPLOAD_NAME=$(echo "$UPLOAD_RESPONSE" | jq -r '.name // empty')
[[ -n "$UPLOAD_NAME" ]] || { echo "Error: upload failed"; exit 1; }

# ── Queue face restore workflow ───────────────────────────────────────
WORKFLOW=$(cat <<WORKFLOW_EOF
{
  "1": {
    "class_type": "LoadImage",
    "inputs": { "image": "$UPLOAD_NAME" }
  },
  "2": {
    "class_type": "FaceRestoreCFWithModel",
    "inputs": {
      "image": ["1", 0],
      "facerestore_model": ["3", 0],
      "fidelity": $FIDELITY
    }
  },
  "3": {
    "class_type": "FaceRestoreModelLoader",
    "inputs": { "model_name": "codeformer.pth" }
  },
  "4": {
    "class_type": "SaveImage",
    "inputs": {
      "images": ["2", 0],
      "filename_prefix": "restored"
    }
  }
}
WORKFLOW_EOF
)

echo "Restoring faces (fidelity=$FIDELITY)..."
QUEUE_RESPONSE=$(curl -sf -X POST "$COMFYUI_URL/prompt" \
  -H "Content-Type: application/json" \
  -d "{\"prompt\": $WORKFLOW}")
PROMPT_ID=$(echo "$QUEUE_RESPONSE" | jq -r '.prompt_id // empty')
[[ -n "$PROMPT_ID" ]] || { echo "Error: failed to queue: $QUEUE_RESPONSE"; exit 1; }

# ── Poll for completion ───────────────────────────────────────────────
for i in $(seq 1 60); do
  HISTORY=$(curl -sf "$COMFYUI_URL/history/$PROMPT_ID")
  STATUS=$(echo "$HISTORY" | jq -r ".[\"$PROMPT_ID\"].status.completed // empty")

  if [[ "$STATUS" == "true" ]]; then
    FILENAME=$(echo "$HISTORY" | jq -r ".[\"$PROMPT_ID\"].outputs[\"4\"].images[0].filename // empty")
    [[ -n "$FILENAME" ]] && break
  fi

  ERROR=$(echo "$HISTORY" | jq -r ".[\"$PROMPT_ID\"].status.status_str // empty")
  [[ "$ERROR" == "error" ]] && { echo "Error: face restore failed"; exit 1; }

  sleep 2
done
[[ -n "${FILENAME:-}" ]] || { echo "Error: timed out"; exit 1; }

# ── Download result ───────────────────────────────────────────────────
curl -sf "$COMFYUI_URL/view?filename=$FILENAME&subfolder=&type=output" \
  -o "$TMPDIR/output.png"

# ── Output ────────────────────────────────────────────────────────────
if [[ -n "$OUTPUT_FOLDER" ]]; then
  echo "Uploading to Drive..."
  gws drive files create \
    --params '{"uploadType": "multipart"}' \
    --json "{\"name\": \"${BASENAME}_restored.png\", \"parents\": [\"$OUTPUT_FOLDER\"]}" \
    --upload "$TMPDIR/output.png" \
    --fields "id,name,webViewLink"
else
  OUTPUT="${OUTPUT:-${INPUT%.*}_restored.png}"
  cp "$TMPDIR/output.png" "$OUTPUT"
  echo "Saved to: $OUTPUT"
fi

echo "Done."
