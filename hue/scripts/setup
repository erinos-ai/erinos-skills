#!/usr/bin/env bash
set -euo pipefail

# Philips Hue provider setup script
# Validates prerequisites. Bridge pairing is done via Erin conversation.

step() { echo ""; echo "── $* ──"; }

step "Prerequisites"

if ! command -v curl &>/dev/null; then
  echo "ERROR: curl is required but not installed."
  exit 1
fi
echo "curl: ok"

# Check bridge discovery
step "Bridge discovery"
echo "Checking for Hue bridges on the network..."
BRIDGES=$(curl -sf https://discovery.meethue.com 2>/dev/null || echo "[]")

if [ "$BRIDGES" = "[]" ]; then
  echo "No bridges found. Make sure your Hue bridge is on the same network."
else
  echo "Found bridge(s):"
  echo "$BRIDGES"
fi

step "Setup complete"
echo "To pair your Hue bridge, tell Erin:"
echo ""
echo "  Connect my Hue lights"
echo ""
echo "Erin will guide you through pressing the bridge button and storing the API key."
